generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  ORGANIZER
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum QuestionType {
  TEXT
  IMAGE
}

enum SessionStatus {
  WAITING
  LIVE
  FINISHED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  displayName         String
  role                UserRole
  createdAt           DateTime             @default(now())
  quizzes             Quiz[]
  sessionsCreated     QuizSession[]        @relation("SessionCreator")
  sessionParticipants SessionParticipant[]

  @@index([role])
}

model Category {
  id         String         @id @default(cuid())
  name       String         @unique
  quizzes    QuizCategory[]
  createdAt  DateTime       @default(now())
}

model Quiz {
  id            String         @id @default(cuid())
  title         String
  description   String?
  status        QuizStatus     @default(DRAFT)
  defaultTime   Int            @default(20)
  isDeleted     Boolean        @default(false)
  createdById   String
  createdBy     User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  questions     Question[]
  categories    QuizCategory[]
  sessions      QuizSession[]
}

model QuizCategory {
  quizId      String
  categoryId  String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([quizId, categoryId])
}

model Question {
  id               String     @id @default(cuid())
  quizId           String
  quiz             Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type             QuestionType
  prompt           String
  imageUrl         String?
  allowMultiple    Boolean    @default(false)
  timeLimitSec     Int?
  orderIndex       Int
  points           Int        @default(100)
  options          Option[]
  answers          Answer[]

  @@unique([quizId, orderIndex])
}

model Option {
  id           String    @id @default(cuid())
  questionId   String
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text         String
  isCorrect    Boolean   @default(false)
  answers      AnswerOption[]
}

model QuizSession {
  id                  String               @id @default(cuid())
  quizId              String
  quiz                Quiz                 @relation(fields: [quizId], references: [id], onDelete: Cascade)
  roomCode            String               @unique
  status              SessionStatus        @default(WAITING)
  createdById         String
  createdBy           User                 @relation("SessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  currentQuestionId   String?
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime             @default(now())
  participants        SessionParticipant[]
  answers             Answer[]

  @@index([quizId, status])
}

model SessionParticipant {
  id            String      @id @default(cuid())
  sessionId     String
  session       QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt      DateTime    @default(now())
  totalScore    Int         @default(0)
  answers       Answer[]

  @@unique([sessionId, userId])
}

model Answer {
  id             String             @id @default(cuid())
  sessionId      String
  session        QuizSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participantId  String
  participant    SessionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  isCorrect      Boolean
  earnedPoints   Int
  submittedAt    DateTime           @default(now())
  selected       AnswerOption[]

  @@unique([sessionId, questionId, participantId])
}

model AnswerOption {
  answerId String
  optionId String
  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  option   Option @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([answerId, optionId])
}
